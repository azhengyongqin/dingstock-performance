generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // Nest 编译产物为 CommonJS，生成的 client 必须同为 CJS，否则生产模式加载报 ESM 冲突。
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  // 固定 schema 前缀：所有表都建在 performance schema 下（见各 model 的 @@schema）。
  schemas  = ["performance"]
}

// ---------------------------------------------------------------------------
// 飞书同步表：字段名与 @larksuiteoapi/node-sdk 对应类型定义保持一致
// （通讯录来源 contact.v3；OKR 来源 okr.v2；SDK v1.71.1）。
// 嵌套对象（avatar/status/orders 等）按 SDK 原始结构存 JSONB；标量数组用 PG 数组。
// ---------------------------------------------------------------------------

/// 飞书员工（contact.v3 user）
model LarkUser {
  open_id                     String   @id /// 用户的 open_id（同步时固定 user_id_type=open_id，必然存在，作主键）
  union_id                    String?  @unique /// 用户的 union_id
  user_id                     String?  @unique /// 租户内用户 ID
  name                        String /// 姓名（list/findByDepartment 响应中必返回）
  en_name                     String? /// 英文名
  nickname                    String? /// 别名
  email                       String? /// 邮箱
  mobile                      String? /// 手机号（依赖应用申请的字段权限，可能不返回）
  mobile_visible              Boolean? /// 手机号是否对他人可见
  gender                      Int? /// 性别：0 保密 / 1 男 / 2 女
  avatar                      Json? /// 头像 AvatarInfo { avatar_72, avatar_240, avatar_640, avatar_origin }
  status                      Json? /// 状态 UserStatus { is_frozen, is_resigned, is_activated, is_exited, is_unjoin }
  department_ids              String[] @default([]) /// 所属部门 ID 列表
  leader_user_id              String? /// 直属上级用户 ID
  city                        String? /// 城市
  country                     String? /// 国家/地区
  work_station                String? /// 工位
  join_time                   Int? /// 入职时间（秒级时间戳，SDK 为 number）
  is_tenant_manager           Boolean? /// 是否租户超级管理员
  employee_no                 String? /// 工号
  employee_type               Int? /// 员工类型：1 正式 / 2 实习 / 3 外包 / 4 劳务 / 5 顾问
  positions                   Json? /// 职位列表 Position[] { position_code, position_name, department_id, leader_user_id, leader_position_code, is_major }
  orders                      Json? /// 部门内排序 UserOrder[] { department_id, user_order, department_order, is_primary_dept }
  custom_attrs                Json? /// 自定义字段 CustomAttr[] { type, id, value{ text, url, pc_url, option_value, name, picture_url, generic_user } }
  enterprise_email            String? /// 企业邮箱
  time_zone                   String? /// 时区
  description                 String? /// 个人签名/描述
  job_title                   String? /// 职务
  geo                         String? /// 数据驻留地
  job_level_id                String? /// 职级 ID
  job_family_id               String? /// 序列 ID
  assign_info                 Json? /// 席位/订阅信息 AssignInfo[] { subscription_id, license_plan_key, product_name, i18n_name, start_time, end_time }
  department_path             Json? /// 部门路径 DepartmentPath[] { department_id, department_name, department_path }
  dotted_line_leader_user_ids String[] @default([]) /// 虚线上级用户 ID 列表

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  corehr                LarkCorehrEmployee? /// CoreHR（飞书人事）员工详情，1:1，可能不存在（未开通/无权限/机器人账号）
  compensation_archives LarkCompensationArchive[] /// 薪资档案历史版本，可能为空（未开通/无薪资权限）

  @@map("lark_users")
  @@schema("performance")
}

/// 飞书人事员工详情（corehr.v2 employee.batchGet，user_id_type=open_id）。
/// 字段名与 SDK 响应保持一致；枚举对象（{ enum_name, display[] }）与嵌套结构存 JSONB。
/// 日期类字段 CoreHR 返回 "YYYY-MM-DD" 字符串，原样存储不做转换。
model LarkCorehrEmployee {
  open_id                     String   @id /// = 响应中的 employment_id（请求固定 user_id_type=open_id），关联 lark_users
  employment_id_v2            String? /// 雇佣 ID（V2 版本）
  employee_number             String? /// 工号
  employee_type_id            String? /// 人员类型 ID
  employee_subtype_id         String? /// 人员子类型 ID
  employment_type             Json? /// 雇佣类型枚举 { enum_name, display[] }
  employment_status           Json? /// 雇佣状态枚举（hired/terminated 等）
  effective_date              String? /// 入职日期
  expiration_date             String? /// 离职日期
  reason_for_offboarding      Json? /// 离职原因枚举
  primary_employment          Boolean? /// 是否主雇佣
  department_id               String? /// 部门 ID（请求固定 department_id_type=open_department_id，可关联 lark_departments）
  company_id                  String? /// 所属公司 ID
  work_location_id            String? /// 工作地点 ID
  working_hours_type_id       String? /// 工时制度 ID
  cost_center_list            Json? /// 成本中心分摊 { cost_center_id, rate }[]
  job_level_id                String? /// 职级 ID
  job_level                   Json? /// 职级详情 { id, level_order, code, name[], active }
  job_grade_id                String? /// 职等 ID
  job_family_id               String? /// 序列 ID
  job_family                  Json? /// 序列详情 { id, name[], active, code }
  position_id                 String? /// 岗位 ID
  position                    Json? /// 岗位详情 { position_id, code, names[] }
  job_id                      String? /// 职务 ID
  job                         Json? /// 职务详情 { id, code, name[] }
  direct_manager_id           String? /// 直属上级（open_id，可关联 lark_users）
  dotted_line_manager_id      String? /// 虚线上级（open_id）
  tenure                      String? /// 司龄（年，字符串小数）
  seniority_date              String? /// 司龄起算日
  probation_period            Int? /// 试用期时长（月）
  on_probation                Boolean? /// 是否在试用期中
  probation_end_date          String? /// 试用期结束日期
  regular_employee_start_date String? /// 转正日期
  rehire                      Json? /// 是否离职重聘枚举
  contract_start_date         String? /// 当前合同开始日期
  contract_end_date           String? /// 当前合同结束日期
  contract_expected_end_date  String? /// 当前合同预计结束日期
  email_address               String? /// 工作邮箱
  work_email_list             Json? /// 工作邮箱列表 { email, email_usage }[]
  avatar_url                  String? /// 头像 URL
  time_zone                   String? /// 时区
  custom_fields               Json? /// 雇佣自定义字段 { custom_api_name, name, type, value }[]
  person_info                 Json? /// 个人信息下钻结果（legal_name/gender/date_of_birth/phone_number 等）

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  user LarkUser @relation(fields: [open_id], references: [open_id], onDelete: Cascade)

  @@index([department_id])
  @@index([direct_manager_id])
  @@map("lark_corehr_employees")
  @@schema("performance")
}

/// 飞书员工薪资档案历史版本（compensation.v1 archive.query，user_id_type=open_id）。
/// tid 是官方定义的档案版本唯一标识；薪资项与指标依赖字段权限，按 SDK 原始结构存 JSONB。
model LarkCompensationArchive {
  tid                String  @id /// 薪资档案版本 ID，官方定义的全局唯一标识
  id                 String /// 薪资档案 ID；同一档案的不同版本可共享该 ID
  open_id            String /// = 响应中的 user_id（请求固定 user_id_type=open_id），关联 lark_users
  plan_id            String? /// 关联薪资方案 ID；依赖 plan 字段权限
  plan_tid           String? /// 关联薪资方案版本 ID；依赖 plan 字段权限
  currency_id        String? /// 档案币种 ID
  change_reason_id   String? /// 调薪原因 ID
  change_description String? /// 调薪说明；依赖 change_description 字段权限
  effective_date     String /// 生效日期（YYYY-MM-DD）
  expiration_date    String? /// 失效日期（YYYY-MM-DD）
  salary_level_id    String? /// 薪级薪等 ID；依赖 salary_level 字段权限
  created_time       String? /// 飞书侧创建时间，按 SDK 字符串原样保存
  updated_time       String? /// 飞书侧更新时间，按 SDK 字符串原样保存
  archive_items      Json? /// 薪资项 [{ item_id, item_result, item_result_regular? }]；依赖 items 字段权限
  archive_indicators Json? /// 薪资指标 [{ indicator_id, indicator_result, indicator_result_regular? }]；依赖 indicators 字段权限

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  user LarkUser @relation(fields: [open_id], references: [open_id], onDelete: Cascade)

  @@index([open_id, effective_date])
  @@index([id])
  @@map("lark_compensation_archives")
  @@schema("performance")
}

/// 飞书部门（contact.v3 department）
model LarkDepartment {
  open_department_id        String   @id /// 部门的 open_department_id（同步时固定 department_id_type=open_department_id，作主键）
  department_id             String? /// 租户内部门 ID
  name                      String /// 部门名称（SDK 类型中必填）
  i18n_name                 Json? /// 多语言名称 { zh_cn, ja_jp, en_us }
  parent_department_id      String /// 父部门 ID（根部门下的一级部门为 "0"；SDK 类型中必填）
  leader_user_id            String? /// 部门负责人用户 ID
  chat_id                   String? /// 部门群 ID
  order                     String? /// 排序权重（SDK 为 string 类型，非 number）
  unit_ids                  String[] @default([]) /// 单位 ID 列表
  member_count              Int? /// 成员数量
  status                    Json? /// 部门状态 { is_deleted }
  leaders                   Json? /// 负责人列表 { leaderType, leaderID }[]
  group_chat_employee_types Int[]    @default([]) /// 部门群员工类型限制列表
  department_hrbps          String[] @default([]) /// 部门 HRBP 用户 ID 列表
  primary_member_count      Int? /// 主属成员数量

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  @@index([parent_department_id])
  @@map("lark_departments")
  @@schema("performance")
}

// ---------------------------------------------------------------------------
// 飞书 OKR v2 同步表：对应 client.okr.v2 的分类、周期、目标、关键结果、
// 指标、进展和对齐关系。SDK 的时间字段是毫秒时间戳字符串，原样存 String；
// 富文本 blocks、多语言名称和单位对象按 SDK 原始结构存 JSONB。
// ---------------------------------------------------------------------------

/// 飞书 OKR 分类（okr.v2.okrCategory.list）。
model LarkOkrCategory {
  id            String  @id /// 飞书 OKR 分类 ID
  create_time   String /// 飞书创建时间（毫秒时间戳字符串）
  update_time   String /// 飞书更新时间（毫秒时间戳字符串）
  category_type String /// 分类类型：person / team
  enabled       Boolean /// 分类是否启用
  color         String /// 飞书预置颜色标识
  name          Json /// 多语言名称 { zh?, en?, ja? }

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  @@index([category_type, enabled])
  @@map("lark_okr_categories")
  @@schema("performance")
}

/// 员工的飞书 OKR 周期（okr.v2.okrCycle.list）。
model LarkOkrCycle {
  id              String @id /// 用户周期 ID
  create_time     String /// 飞书创建时间（毫秒时间戳字符串）
  update_time     String /// 飞书更新时间（毫秒时间戳字符串）
  tenant_cycle_id String /// 租户级 OKR 周期 ID
  owner_type      String /// SDK 当前固定为 user
  owner_open_id   String /// 请求固定 user_id_type=open_id；SDK owner.user_id 的本地口径
  start_time      String /// 周期开始时间（毫秒时间戳字符串）
  end_time        String /// 周期结束时间（毫秒时间戳字符串）
  cycle_status    Int? /// 飞书周期状态枚举值
  score           Float? /// 周期评分

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  objectives LarkOkrObjective[]

  @@index([owner_open_id, start_time])
  @@index([tenant_cycle_id])
  @@index([cycle_status])
  @@map("lark_okr_cycles")
  @@schema("performance")
}

/// 飞书 OKR 目标（okr.v2.okrCycleObjective.list）。
model LarkOkrObjective {
  id            String  @id /// 目标 ID
  create_time   String /// 飞书创建时间（毫秒时间戳字符串）
  update_time   String /// 飞书更新时间（毫秒时间戳字符串）
  owner_type    String /// SDK 当前固定为 user
  owner_open_id String /// 请求固定 user_id_type=open_id；SDK owner.user_id 的本地口径
  cycle_id      String /// 所属用户周期 ID
  position      Int /// 目标在周期内的位置
  content       Json? /// 富文本内容 blocks，结构来自 SDK okr.v2
  score         Float? /// 目标评分
  notes         Json? /// 富文本备注 blocks，结构来自 SDK okr.v2
  weight        Float? /// 目标权重
  deadline      String? /// 截止时间（SDK 字符串原样保存）
  category_id   String? /// 飞书分类 ID；仅作逻辑引用，避免分类权限缺失阻断目标同步

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  cycle       LarkOkrCycle       @relation(fields: [cycle_id], references: [id], onDelete: Cascade)
  key_results LarkOkrKeyResult[]

  @@index([cycle_id, position])
  @@index([owner_open_id])
  @@index([category_id])
  @@map("lark_okr_objectives")
  @@schema("performance")
}

/// 飞书 OKR 关键结果（okr.v2.okrObjectiveKeyResult.list）。
model LarkOkrKeyResult {
  id            String  @id /// 关键结果 ID
  create_time   String /// 飞书创建时间（毫秒时间戳字符串）
  update_time   String /// 飞书更新时间（毫秒时间戳字符串）
  owner_type    String /// SDK 当前固定为 user
  owner_open_id String /// 请求固定 user_id_type=open_id；SDK owner.user_id 的本地口径
  objective_id  String /// 所属目标 ID
  position      Int /// 关键结果在目标内的位置
  content       Json? /// 富文本内容 blocks，结构来自 SDK okr.v2
  score         Float? /// 关键结果评分
  weight        Float? /// 关键结果权重
  deadline      String? /// 截止时间（SDK 字符串原样保存）

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  objective LarkOkrObjective @relation(fields: [objective_id], references: [id], onDelete: Cascade)

  @@index([objective_id, position])
  @@index([owner_open_id])
  @@map("lark_okr_key_results")
  @@schema("performance")
}

/// 飞书 OKR 量化指标；objective / key_result 共用同一结构，以 entity_type + entity_id 定位。
model LarkOkrIndicator {
  id                           String  @id /// 指标 ID
  create_time                  String /// 飞书创建时间（毫秒时间戳字符串）
  update_time                  String /// 飞书更新时间（毫秒时间戳字符串）
  owner_type                   String /// SDK 当前固定为 user
  owner_open_id                String? /// 请求固定 user_id_type=open_id；SDK owner.user_id
  entity_type                  Int /// 飞书实体类型枚举值（目标或关键结果）
  entity_id                    String /// 目标或关键结果 ID
  indicator_status             Int /// 指标状态枚举值
  status_calculate_type        Int /// 状态计算方式枚举值
  start_value                  Float? /// 起始值
  target_value                 Float? /// 目标值
  current_value                Float? /// 当前值
  current_value_calculate_type Int? /// 当前值计算方式枚举值
  unit                         Json? /// 指标单位 { unit_type, unit_value }

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  @@unique([entity_type, entity_id])
  @@index([owner_open_id])
  @@map("lark_okr_indicators")
  @@schema("performance")
}

/// 飞书 OKR 进展；objective / key_result 共用同一结构，以 entity_type + entity_id 定位。
model LarkOkrProgress {
  id               String  @id /// 进展记录 ID
  create_time      String /// 飞书创建时间（毫秒时间戳字符串）
  update_time      String /// 飞书更新时间（毫秒时间戳字符串）
  owner_type       String /// SDK 当前固定为 user
  owner_open_id    String? /// 请求固定 user_id_type=open_id；SDK owner.user_id
  entity_type      Int /// 飞书实体类型枚举值（目标或关键结果）
  entity_id        String /// 目标或关键结果 ID
  content          Json? /// 进展富文本 blocks，结构来自 SDK okr.v2
  progress_percent Float? /// 进展百分比
  progress_status  Int? /// 进展状态枚举值

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  @@index([entity_type, entity_id, create_time])
  @@index([owner_open_id])
  @@map("lark_okr_progresses")
  @@schema("performance")
}

/// 飞书 OKR 目标对齐关系（okr.v2.okrObjectiveAlignment.list）。
model LarkOkrAlignment {
  id               String  @id /// 对齐关系 ID
  create_time      String /// 飞书创建时间（毫秒时间戳字符串）
  update_time      String /// 飞书更新时间（毫秒时间戳字符串）
  from_owner_type  String /// 来源拥有者类型，SDK 当前固定为 user
  from_owner_id    String? /// 来源拥有者 open_id
  to_owner_type    String /// 目标拥有者类型，SDK 当前固定为 user
  to_owner_id      String? /// 目标拥有者 open_id
  from_entity_type Int /// 来源实体类型枚举值
  from_entity_id   String /// 来源实体 ID
  to_entity_type   Int /// 目标实体类型枚举值
  to_entity_id     String /// 目标实体 ID

  // ---- 以下为本地同步簿记字段（非 SDK 字段）----
  created_at DateTime @default(now()) /// 首次入库时间
  synced_at  DateTime @updatedAt /// 最近一次同步时间

  @@index([from_entity_type, from_entity_id])
  @@index([to_entity_type, to_entity_id])
  @@index([from_owner_id])
  @@index([to_owner_id])
  @@map("lark_okr_alignments")
  @@schema("performance")
}

// ---------------------------------------------------------------------------
// 绩效业务域（研发说明文档 §7、产品详细设计文档 §8）
// 约定：
// - 员工引用统一存飞书 open_id（String），不建到 lark_users 的物理外键——
//   同步表会全量重建/删除，业务历史必须独立存活；展示层 join lark_users。
// - 快照字段（部门/职级/Leader）在周期启动时写入，组织变动不影响历史。
// - 动态表单 schema、评分明细、AI 输出、灵活规则一律 JSONB。
// - 状态字段使用 Prisma enum，与后端状态机一一对应。
// - perf_participants 是单人评估过程的聚合根，过程数据全部挂 participant_id。
// - 校准记录与操作日志 append-only：无 updated_at/deleted_at，禁止 UPDATE。
// ---------------------------------------------------------------------------

/// 周期类型；首期只用半年度，季度/年度预留
enum PerfCycleType {
  SEMI_ANNUAL /// 半年度
  QUARTERLY /// 季度（预留）
  ANNUAL /// 年度（预留）

  @@schema("performance")
}

/// 周期只保存粗粒度生命周期；具体评估进度由任务和参与人事实派生。
enum PerfCycleStatus {
  DRAFT /// 草稿：允许配置与名单调整
  SCHEDULED /// 待启动：通过启动检查，等待计划启动
  ACTIVE /// 进行中：各人工任务可并行推进
  ARCHIVED /// 已归档：永久只读终态

  @@schema("performance")
}

/// 周期启动时生成的统一任务事实类型；AI 独立异步，不属于人工阶段状态机。
enum PerfEvaluationTaskType {
  SELF /// 员工自评
  PEER /// 360° 评估协调任务
  MANAGER /// 上级评估
  AI /// AI 异步参考任务

  @@schema("performance")
}

/// 参与者状态机（研发文档 §8.2），周期整体状态按参与者聚合推进
enum PerfParticipantStatus {
  ACTIVE /// 新生命周期中的进行中默认态；评估进度由任务/提交事实派生
  CALIBRATED /// 已校准
  RESULT_PUBLISHED /// 当前不可变结果版本已发布，等待员工确认或申诉
  CONFIRMED /// 员工已确认
  APPEALING /// 申诉中
  RE_CONFIRMING /// 申诉处理后再次确认中
  NO_RESULT /// 当前周期无绩效结果：始终缺失必需自评，不生成校准或最终结果，归档前可撤销
  WITHDRAWN /// 中途退出：与无绩效结果区分，归档后作为历史事实永久只读

  @@schema("performance")
}

/// 系统角色（产品 §3）；EMPLOYEE/REVIEWER/LEADER 为任务关系派生角色，
/// role_grants 表仅显式授权 HR/ADMIN，枚举全集用于维度可见/可填角色配置
enum PerfRole {
  EMPLOYEE /// 员工（被考核人）
  REVIEWER /// 评审员
  LEADER /// 直属 Leader
  HR /// HR
  ADMIN /// 超级管理员

  @@schema("performance")
}

/// 评审员与被评人的关系（产品 §6.4.1 推荐来源）
enum PerfReviewerRelation {
  LEADER /// 直属上级
  PEER /// 同部门同事
  CROSS_DEPT /// 跨部门协作方
  ORG_OWNER /// 组织负责人
  PROJECT_OWNER /// 项目负责人

  @@schema("performance")
}

/// 评审员指派来源
enum PerfReviewerSource {
  RECOMMENDED /// 系统推荐
  LEADER_ASSIGNED /// Leader 指定
  HR_ASSIGNED /// HR 补充指派

  @@schema("performance")
}

/// 评审指派状态；更换评审员 = 旧记录置 REPLACED + 新建记录，不做物理删除
enum PerfAssignmentStatus {
  PENDING /// 待评审
  SUBMITTED /// 已提交评估
  REPLACED /// 已被更换（保留痕迹）

  @@schema("performance")
}

/// 评估记录状态（360° 与上级评估共用；统一评估提交 PerfEvaluationSubmission 同样复用此两态表达草稿/生效）
enum PerfReviewStatus {
  DRAFT /// 草稿
  SUBMITTED /// 已提交
  INVALIDATED /// 表单结构变化后失效的历史答卷；保留旧快照与答案，但不参与当前填写或计算

  @@schema("performance")
}

/// AI 报告生成任务状态（研发文档 §8.6：DB 任务表 + cron 轮询）
enum PerfAiReportStatus {
  PENDING /// 待生成或输入已变化后等待重新生成
  GENERATING /// 生成中；processingRevision 固定本次领取的输入修订
  SUCCESS /// 生成成功
  FAILED /// 生成失败或超时；到达 availableAt 后可自动重试，也支持授权角色手动重跑

  @@schema("performance")
}

/// Leader/HR 对 AI 报告的处理动作
enum PerfAiReviewAction {
  ADOPTED /// 采纳
  IGNORED /// 忽略
  EDITED /// 编辑后采纳

  @@schema("performance")
}

/// 申诉状态（产品 §8.17）
enum PerfAppealStatus {
  PENDING /// 待处理
  IN_INTERVIEW /// 面谈处理中
  RESOLVED /// 已处理

  @@schema("performance")
}

/// 面谈类型（产品 §8.18）
enum PerfInterviewType {
  APPEAL /// 申诉面谈
  OPTIONAL /// 选择性面谈

  @@schema("performance")
}

/// 通知发送通道（产品 §8.19）
enum PerfNotificationChannel {
  BOT_DM /// 机器人私聊消息
  CARD /// 交互卡片
  GROUP_BOT /// 群机器人

  @@schema("performance")
}

/// 通知发送状态；PENDING 为入库待发，RETRYING 指数退避重试中
enum PerfNotificationStatus {
  PENDING /// 待发送
  SUCCESS /// 发送成功
  FAILED /// 重试上限后失败，支持手动补发
  RETRYING /// 重试中

  @@schema("performance")
}

/// 业务通知事件类型；业务动作先写 outbox，再由通知模块异步转换为发送记录。
enum PerfNotificationEventType {
  TASK_OPENED /// 人工评估任务到时开放
  TASK_REMINDER_DUE /// 人工评估任务到达软提醒时间
  CYCLE_START_FAILED /// 待启动周期到时复核失败
  RESULT_PUBLISHED /// 结果版本发布，通知员工查看并确认
  RESULT_INVALIDATED /// 周期整体退回后，通知已收到结果的员工旧结果链失效

  @@schema("performance")
}

/// 通知事件消费状态；RETRYING 按 availableAt 退避，FAILED 保留供人工补偿。
enum PerfNotificationEventStatus {
  PENDING /// 等待消费
  RETRYING /// 消费失败，等待重试
  COMPLETED /// 已幂等转换为通知发送记录
  FAILED /// 超过自动重试上限

  @@schema("performance")
}

/// 报表导出任务状态（研发文档 §8.7 异步任务模型）
enum ReportExportStatus {
  PENDING /// 排队中
  PROCESSING /// 生成中
  SUCCESS /// 已完成
  FAILED /// 失败

  @@schema("performance")
}

/// 评估表单模板版本生命周期；只有 DRAFT 可修改表单结构。
enum PerfFormTemplateVersionStatus {
  DRAFT /// 草稿：允许编辑，不能被配置模板引用
  PUBLISHED /// 已发布：内容不可变，可供配置模板选择
  ARCHIVED /// 已归档：仅保留历史，不再用于新配置

  @@schema("performance")
}

/// 配置模板版本生命周期；发布版本作为周期配置来源，不允许原地改写。
enum PerfConfigTemplateVersionStatus {
  DRAFT /// 草稿：允许编辑，但不能创建周期
  PUBLISHED /// 已发布：内容不可变，可供 HR 选择
  ARCHIVED /// 已归档：仅保留历史，不再用于新的周期

  @@schema("performance")
}

/// 阶段结果数据状态：READY=有有效输入并完成计算；NO_DATA=没有有效输入，不伪造零分或等级。
enum PerfStageResultStatus {
  READY
  NO_DATA

  @@schema("performance")
}

/// 校准决定必须显式区分沿用权威等级与人工调整，避免“没有决定”被误解为维持。
enum PerfCalibrationDecision {
  KEEP /// 沿用当前 MANAGER 权威阶段等级
  ADJUST /// 人工调整为另一个等级，必须填写原因

  @@schema("performance")
}

/// 红线事实采用 append-only 事件表达；撤销事件引用被撤销的确认事件。
enum PerfRedLineAction {
  CONFIRM /// HR/Admin 确认红线
  REVOKE /// HR/Admin 撤销一条仍有效的确认

  @@schema("performance")
}

/// 系统当前支持的职级前缀；参与者按职级快照前缀匹配表单版本。
enum PerfJobLevelPrefix {
  D /// 普通岗位
  M /// 管理岗位

  @@schema("performance")
}

/// 人工绩效使用前三类子表单；PROMOTION 仅保留旧版本历史读取。
enum PerfFormSubformType {
  SELF /// 员工自评
  PEER /// 360°评估
  MANAGER /// 上级评估
  PROMOTION /// 晋升评估

  @@schema("performance")
}

/// 表单维度类型；旧晋升内容仅用于只读历史，不进入绩效发布与提交链。
enum PerfFormDimensionType {
  SCORING /// 计分维度
  NON_SCORING /// 非计分维度
  LEGACY_PROMOTION /// 旧晋升内容，只读保留

  @@schema("performance")
}

/// 计分维度直接持有的输入方式。
enum PerfFormScoringMethod {
  RATING /// S/A/B/C 评级选择
  SCORE /// 0～100 分数输入

  @@schema("performance")
}

/// 表单字段的正式提交必填规则。
enum PerfFormFieldRequiredRule {
  OPTIONAL /// 选填
  ALWAYS /// 始终必填
  CONDITIONAL /// 命中维度等级时必填

  @@schema("performance")
}

/// 维度内容的填写对象；晋升内容只允许 EMPLOYEE 与 LEADER。
enum PerfFormAudience {
  EMPLOYEE /// 被考核员工
  REVIEWER /// 360°评审员
  LEADER /// 考核 Leader

  @@schema("performance")
}

/// 受控表单字段目录；计分输入归属维度，不属于字段。
enum PerfFormFieldType {
  SHORT_TEXT /// 单行文本
  LONG_TEXT /// 多行文本
  MARKDOWN /// Markdown 内容
  SINGLE_SELECT /// 单选
  MULTI_SELECT /// 多选
  ATTACHMENT /// 文件附件
  LINK /// 链接

  @@schema("performance")
}

/// 固定 S/A/B/C 四档评级符号（ADR-0019）；维度原始评级与阶段等级均引用此枚举，不接受任意字符串。
enum PerfRatingSymbol {
  S
  A
  B
  C

  @@schema("performance")
}

/// 评估表单模板的稳定标识；名称、适用职级与表单内容都保存在不可变版本中。
model PerfFormTemplate {
  id              Int      @id @default(autoincrement()) /// 内部自增主键
  systemKey       String?  @unique @map("system_key") /// 内置模板幂等键（如 DEFAULT_D）；管理员自建模板为空
  createdByOpenId String   @map("created_by_open_id") /// 创建人飞书 open_id
  createdAt       DateTime @default(now()) @map("created_at") /// 创建时间
  updatedAt       DateTime @updatedAt @map("updated_at") /// 最近更新时间

  versions PerfFormTemplateVersion[]

  @@map("perf_form_templates")
  @@schema("performance")
}

/// 评估表单模板版本；发布后由数据库触发器保护，结构与内容不可原地修改。
model PerfFormTemplateVersion {
  id                Int                           @id @default(autoincrement()) /// 内部自增主键
  templateId        Int                           @map("template_id") /// 所属稳定模板
  version           Int /// 模板内递增版本号，从 1 开始
  status            PerfFormTemplateVersionStatus @default(DRAFT) /// 版本生命周期
  name              String /// 版本名称；作为发布内容的一部分保持不可变
  description       String? /// 版本说明
  jobLevelPrefix    PerfJobLevelPrefix            @map("job_level_prefix") /// 唯一适用的系统职级前缀
  sourceVersionId   Int?                          @map("source_version_id") /// 从哪个已发布版本复制出的草稿；首版为空
  createdByOpenId   String                        @map("created_by_open_id") /// 创建版本的管理员 open_id
  updatedByOpenId   String                        @map("updated_by_open_id") /// 最近修改版本的管理员 open_id
  publishedByOpenId String?                       @map("published_by_open_id") /// 发布人 open_id
  publishedAt       DateTime?                     @map("published_at") /// 发布时间
  archivedByOpenId  String?                       @map("archived_by_open_id") /// 归档人 open_id
  archivedAt        DateTime?                     @map("archived_at") /// 归档时间
  createdAt         DateTime                      @default(now()) @map("created_at") /// 创建时间
  updatedAt         DateTime                      @updatedAt @map("updated_at") /// 最近更新时间

  template        PerfFormTemplate          @relation(fields: [templateId], references: [id], onDelete: Restrict)
  sourceVersion   PerfFormTemplateVersion?  @relation("PerfFormTemplateVersionSource", fields: [sourceVersionId], references: [id], onDelete: Restrict)
  derivedVersions PerfFormTemplateVersion[] @relation("PerfFormTemplateVersionSource")
  subforms        PerfFormSubform[]
  configBindings  PerfConfigFormBinding[]
  cycleSnapshots  PerfCycleFormSnapshot[]   @relation("PerfCycleFormSnapshotSource")

  @@unique([templateId, version])
  /// 供配置模板绑定使用；冗余职级前缀进入复合外键，防止绑定记录伪造适用前缀。
  @@unique([id, jobLevelPrefix])
  @@index([templateId, status])
  @@index([status, jobLevelPrefix])
  @@index([sourceVersionId])
  @@map("perf_form_template_versions")
  @@schema("performance")
}

/// 表单版本下的子表单；新版发布只要求 SELF / PEER / MANAGER，旧 PROMOTION 不参与发布。
model PerfFormSubform {
  id          Int                 @id @default(autoincrement()) /// 内部自增主键
  versionId   Int                 @map("version_id") /// 所属评估表单模板版本
  type        PerfFormSubformType /// SELF / PEER / MANAGER / PROMOTION
  title       String /// 子表单标题
  description String? /// 填写说明
  sortOrder   Int                 @default(0) @map("sort_order") /// 版本内展示顺序，必须非负且唯一
  createdAt   DateTime            @default(now()) @map("created_at") /// 创建时间
  updatedAt   DateTime            @updatedAt @map("updated_at") /// 最近更新时间

  version    PerfFormTemplateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  dimensions PerfFormDimension[]

  @@unique([versionId, type])
  @@unique([versionId, sortOrder])
  @@map("perf_form_subforms")
  @@schema("performance")
}

/// 子表单维度；权重与核心标记只属于计分维度。
model PerfFormDimension {
  id          Int                   @id @default(autoincrement()) /// 内部自增主键
  subformId   Int                   @map("subform_id") /// 所属子表单
  businessKey String                @default(uuid()) @map("business_key") /// 跨版本不变的业务标识；改名、换序、改类型均不改变
  type        PerfFormDimensionType @default(SCORING) /// 计分、非计分或只读旧晋升维度
  scoringMethod PerfFormScoringMethod? @map("scoring_method") /// 计分维度直接持有评级或分数方式；非计分维度为空
  audience    PerfFormAudience /// 填写对象；发布校验限制各子表单允许的对象
  name        String /// 维度名称
  description String? /// 维度说明与评价边界
  weight      Decimal?              @db.Decimal(5, 2) /// 常规加权维度权重（百分比）；非加权维度为空
  isCore      Boolean               @default(false) @map("is_core") /// 是否核心维度；加权子表单发布时恰好一个
  sortOrder   Int                   @default(0) @map("sort_order") /// 同一填写对象内展示顺序，必须非负且唯一
  createdAt   DateTime              @default(now()) @map("created_at") /// 创建时间
  updatedAt   DateTime              @updatedAt @map("updated_at") /// 最近更新时间

  subform PerfFormSubform @relation(fields: [subformId], references: [id], onDelete: Cascade)
  fields  PerfFormField[]

  @@unique([subformId, audience, sortOrder])
  @@unique([subformId, businessKey])
  @@index([subformId, type])
  @@index([businessKey])
  @@map("perf_form_dimensions")
  @@schema("performance")
}

/// 受控表单字段；类型专属选项、长度与数量限制存入经服务层校验的 config JSONB。
model PerfFormField {
  id          Int              @id @default(autoincrement()) /// 内部自增主键
  dimensionId Int              @map("dimension_id") /// 所属表单维度
  businessKey String           @default(uuid()) @map("business_key") /// 跨版本不变的字段业务标识；删除后不复用
  type        PerfFormFieldType /// 受控字段类型
  title       String /// 表单字段标题
  description String? /// 表单字段说明
  placeholder String? /// 输入占位提示
  requiredRule PerfFormFieldRequiredRule @default(OPTIONAL) @map("required_rule") /// 新版字段必填规则
  requiredLevels PerfRatingSymbol[] @default([]) @map("required_levels") /// CONDITIONAL 规则触发的维度等级
  sortOrder   Int              @default(0) @map("sort_order") /// 维度内展示顺序，必须非负且唯一
  config      Json? /// 类型专属配置；不允许存任意脚本或 HTML
  createdAt   DateTime         @default(now()) @map("created_at") /// 创建时间
  updatedAt   DateTime         @updatedAt @map("updated_at") /// 最近更新时间

  dimension PerfFormDimension @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@unique([dimensionId, sortOrder])
  @@index([businessKey])
  @@map("perf_form_fields")
  @@schema("performance")
}

/// 配置模板的稳定标识；名称、计算规则与表单组合均保存在不可变版本中。
model PerfConfigTemplate {
  id              Int      @id @default(autoincrement()) /// 内部自增主键
  systemKey       String?  @unique @map("system_key") /// 内置模板幂等键；管理员自建模板为空
  createdByOpenId String   @map("created_by_open_id") /// 创建人飞书 open_id
  createdAt       DateTime @default(now()) @map("created_at") /// 创建时间
  updatedAt       DateTime @updatedAt @map("updated_at") /// 最近更新时间

  versions PerfConfigTemplateVersion[]

  @@map("perf_config_templates")
  @@schema("performance")
}

/// 配置模板版本；发布后由数据库触发器保护，规则与表单绑定均不可原地修改。
model PerfConfigTemplateVersion {
  id                 Int                             @id @default(autoincrement()) /// 内部自增主键
  templateId         Int                             @map("template_id") /// 所属稳定配置模板
  version            Int /// 模板内递增版本号，从 1 开始
  status             PerfConfigTemplateVersionStatus @default(DRAFT) /// 版本生命周期
  name               String /// 版本名称；作为发布内容的一部分保持不可变
  description        String? /// 版本说明
  sourceVersionId    Int?                            @map("source_version_id") /// 从哪个已发布版本复制出的草稿；首版为空
  ratings            Json                            @default("[]") /// 固定 S/A/B/C 顺序的等级名称、区间与映射分
  orgOwnerWeight     Decimal                         @default(30) @map("org_owner_weight") @db.Decimal(5, 2) /// 组织负责人基础权重
  projectOwnerWeight Decimal                         @default(30) @map("project_owner_weight") @db.Decimal(5, 2) /// 项目负责人基础权重
  peerWeight         Decimal                         @default(25) @map("peer_weight") @db.Decimal(5, 2) /// 同部门同事基础权重
  crossDeptWeight    Decimal                         @default(15) @map("cross_dept_weight") @db.Decimal(5, 2) /// 跨部门协作方基础权重
  schedulePreset     Json                            @default("{}") @map("schedule_preset") /// 相对计划启动时间的任务开放与软提醒预设
  notificationRules  Json                            @default("{}") @map("notification_rules") /// 飞书通知事件、接收人、抄送人与提醒频率
  createdByOpenId    String                          @map("created_by_open_id") /// 创建版本的管理员 open_id
  updatedByOpenId    String                          @map("updated_by_open_id") /// 最近修改版本的管理员 open_id
  publishedByOpenId  String?                         @map("published_by_open_id") /// 发布人 open_id
  publishedAt        DateTime?                       @map("published_at") /// 发布时间
  archivedByOpenId   String?                         @map("archived_by_open_id") /// 归档人 open_id
  archivedAt         DateTime?                       @map("archived_at") /// 归档时间
  createdAt          DateTime                        @default(now()) @map("created_at") /// 创建时间
  updatedAt          DateTime                        @updatedAt @map("updated_at") /// 最近更新时间

  template        PerfConfigTemplate          @relation(fields: [templateId], references: [id], onDelete: Restrict)
  sourceVersion   PerfConfigTemplateVersion?  @relation("PerfConfigTemplateVersionSource", fields: [sourceVersionId], references: [id], onDelete: Restrict)
  derivedVersions PerfConfigTemplateVersion[] @relation("PerfConfigTemplateVersionSource")
  formBindings    PerfConfigFormBinding[]
  cycleVersions   PerfCycleConfigVersion[]    @relation("PerfCycleConfigVersionSource")

  @@unique([templateId, version])
  @@index([templateId, status])
  @@index([status])
  @@index([sourceVersionId])
  @@map("perf_config_template_versions")
  @@schema("performance")
}

/// 配置版本对已发布评估表单版本的精确绑定；职级前缀由复合外键保证与表单版本一致。
model PerfConfigFormBinding {
  id                    Int                @id @default(autoincrement()) /// 内部自增主键
  configVersionId       Int                @map("config_version_id") /// 所属配置模板版本
  formTemplateVersionId Int                @map("form_template_version_id") /// 被绑定的评估表单模板版本
  jobLevelPrefix        PerfJobLevelPrefix @map("job_level_prefix") /// 冗余职级前缀；配置版本内每个前缀只能绑定一次
  createdAt             DateTime           @default(now()) @map("created_at") /// 创建时间
  updatedAt             DateTime           @updatedAt @map("updated_at") /// 最近更新时间

  configVersion       PerfConfigTemplateVersion @relation(fields: [configVersionId], references: [id], onDelete: Cascade)
  formTemplateVersion PerfFormTemplateVersion   @relation(fields: [formTemplateVersionId, jobLevelPrefix], references: [id, jobLevelPrefix], onDelete: Restrict)

  @@unique([configVersionId, jobLevelPrefix])
  @@index([formTemplateVersionId])
  @@map("perf_config_form_bindings")
  @@schema("performance")
}

/// 周期内独立的计算配置快照版本；首版从已发布配置模板复制，后续版本不回写模板。
model PerfCycleConfigVersion {
  id                            Int                 @id @default(autoincrement()) /// 内部自增主键
  cycleId                       Int                 @map("cycle_id") /// 所属绩效周期
  version                       Int /// 周期内递增版本号，从 1 开始
  sourceConfigTemplateVersionId Int?                @map("source_config_template_version_id") /// 来源配置模板版本；历史回填可为空
  ratings                       Json /// 固定 S/A/B/C 的等级、区间和映射分快照
  orgOwnerWeight                Decimal             @map("org_owner_weight") @db.Decimal(5, 2) /// 组织负责人基础权重
  projectOwnerWeight            Decimal             @map("project_owner_weight") @db.Decimal(5, 2) /// 项目负责人基础权重
  peerWeight                    Decimal             @map("peer_weight") @db.Decimal(5, 2) /// 同部门同事基础权重
  crossDeptWeight               Decimal             @map("cross_dept_weight") @db.Decimal(5, 2) /// 跨部门协作方基础权重
  schedulePreset                Json                @map("schedule_preset") /// 相对计划启动时间的开放与软提醒规则
  notificationRules             Json                @map("notification_rules") /// 飞书通知接收人、抄送人与提醒频率快照
  createdByOpenId               String              @map("created_by_open_id") /// 创建快照版本的操作者 open_id
  createdAt                     DateTime            @default(now()) @map("created_at") /// 创建时间
  updatedAt                     DateTime            @updatedAt @map("updated_at") /// DRAFT / SCHEDULED 阶段的最近调整时间

  cycle               PerfCycle                  @relation("PerfCycleConfigVersions", fields: [cycleId], references: [id], onDelete: Cascade)
  currentForCycle     PerfCycle?                 @relation("PerfCycleCurrentConfigVersion")
  sourceConfigVersion PerfConfigTemplateVersion? @relation("PerfCycleConfigVersionSource", fields: [sourceConfigTemplateVersionId], references: [id], onDelete: Restrict)
  formSnapshots       PerfCycleFormSnapshot[]
  stageResults        PerfStageResult[]

  @@unique([cycleId, version])
  /// 表单快照用复合外键锁定配置版本与周期，防止跨周期挂载。
  @@unique([id, cycleId])
  @@index([sourceConfigTemplateVersionId])
  @@map("perf_cycle_config_versions")
  @@schema("performance")
}

/// 周期表单快照；每个配置版本对 D/M 前缀各保存一份完整且独立的表单内容。
model PerfCycleFormSnapshot {
  id                          Int                @id @default(autoincrement()) /// 内部自增主键
  cycleConfigVersionId        Int                @map("cycle_config_version_id") /// 所属周期配置版本
  cycleId                     Int                @map("cycle_id") /// 冗余周期 ID，用于复合外键阻止跨周期挂载
  jobLevelPrefix              PerfJobLevelPrefix @map("job_level_prefix") /// 受控 D/M 职级前缀
  sourceFormTemplateVersionId Int                @map("source_form_template_version_id") /// 来源已发布表单版本
  content                     Json /// v2 完整子表单、维度、字段、条件必填与稳定业务 key 的 JSONB
  createdAt                   DateTime           @default(now()) @map("created_at") /// 创建时间
  updatedAt                   DateTime           @updatedAt @map("updated_at") /// DRAFT / SCHEDULED 阶段的最近调整时间

  configVersion         PerfCycleConfigVersion     @relation(fields: [cycleConfigVersionId, cycleId], references: [id, cycleId], onDelete: Cascade)
  sourceFormVersion     PerfFormTemplateVersion    @relation("PerfCycleFormSnapshotSource", fields: [sourceFormTemplateVersionId], references: [id], onDelete: Restrict)
  participants          PerfParticipant[]
  evaluationSubmissions PerfEvaluationSubmission[]

  @@unique([cycleConfigVersionId, jobLevelPrefix])
  @@index([cycleId])
  @@index([sourceFormTemplateVersionId])
  @@map("perf_cycle_form_snapshots")
  @@schema("performance")
}

/// 绩效周期：评审活动顶层聚合；名称表达业务期间，仅 DRAFT 允许软删除。
model PerfCycle {
  id                     Int             @id @default(autoincrement()) /// 内部自增主键
  name                   String /// 周期名称，如「2026 上半年绩效评定」；直接承担业务期间表达
  type                   PerfCycleType   @default(SEMI_ANNUAL) /// 周期类型
  status                 PerfCycleStatus @default(DRAFT) /// DRAFT / SCHEDULED / ACTIVE / ARCHIVED 粗粒度生命周期
  plannedStartAt         DateTime?       @map("planned_start_at") /// 计划启动时间；相对日程换算绝对时间的唯一锚点
  ownerOpenId            String          @map("owner_open_id") /// 周期负责人（HR）飞书 open_id
  currentConfigVersionId Int?            @unique @map("current_config_version_id") /// 创建事务内短暂为空；对外可见周期必须绑定
  createdAt              DateTime        @default(now()) @map("created_at") /// 创建时间
  updatedAt              DateTime        @updatedAt @map("updated_at") /// 最近更新时间
  deletedAt              DateTime?       @map("deleted_at") /// 软删除时间；仅 DRAFT 可删，查询默认过滤 null

  /// 复合外键同时校验当前配置版本属于本周期，禁止跨周期切换指针。
  currentConfigVersion  PerfCycleConfigVersion?    @relation("PerfCycleCurrentConfigVersion", fields: [currentConfigVersionId, id], references: [id, cycleId], onDelete: Restrict)
  configVersions        PerfCycleConfigVersion[]   @relation("PerfCycleConfigVersions")
  participants          PerfParticipant[]
  evaluationTasks       PerfEvaluationTask[]
  evaluationSubmissions PerfEvaluationSubmission[]
  notificationEvents    PerfNotificationEvent[]
  reviewerAssignments   PerfReviewerAssignment[]
  stageResults          PerfStageResult[]
  exportTasks           ReportExportTask[]
  rollbacks             PerfCycleRollback[]
  archive               PerfCycleArchive?

  @@unique([currentConfigVersionId, id])
  @@index([status, plannedStartAt])
  @@index([deletedAt])
  @@map("perf_cycles")
  @@schema("performance")
}

/// 周期归档的不可变快照；保存用户确认过的关闭统计、全量检查结果与操作者。
/// archivedAt 即该 append-only 事实的创建时间，因此不另设 updatedAt / deletedAt。
model PerfCycleArchive {
  id             Int      @id @default(autoincrement()) /// 内部自增主键
  cycleId        Int      @unique @map("cycle_id") /// 被归档周期；一周期至多一条归档事实
  operatorOpenId String   @map("operator_open_id") /// 执行归档的 Admin 或覆盖全员的 HR open_id
  summary        Json /// 归档时关闭统计快照：总人数、确认/无结果/退出人数、等级分布
  checkResult    Json     @map("check_result") /// 全量关闭检查快照：revision 与 blockers（成功时为空数组）
  archivedAt     DateTime @default(now()) @map("archived_at") /// 永久归档发生时间

  cycle PerfCycle @relation(fields: [cycleId], references: [id], onDelete: Restrict)

  @@index([operatorOpenId])
  @@index([archivedAt])
  @@map("perf_cycle_archives")
  @@schema("performance")
}

/// ACTIVE 周期整体退回记录；append-only 保存操作者、目标状态与执行时完整影响统计。
model PerfCycleRollback {
  id             Int             @id @default(autoincrement()) /// 内部自增主键，同时作为失效链与通知幂等业务键
  cycleId        Int             @map("cycle_id") /// 被退回的周期
  targetStatus   PerfCycleStatus @map("target_status") /// 仅允许 DRAFT / SCHEDULED，由服务与迁移约束双重保证
  reason         String /// 超级管理员填写的退回原因
  impactSummary  Json            @map("impact_summary") /// 执行时冻结的影响统计与预览修订
  operatorOpenId String          @map("operator_open_id") /// 执行退回的超级管理员 open_id
  createdAt      DateTime        @default(now()) @map("created_at") /// 退回发生时间

  cycle                     PerfCycle           @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  invalidatedCalibrations   PerfCalibration[]
  invalidatedResultVersions PerfResultVersion[]
  invalidatedAppeals        PerfAppeal[]

  @@index([cycleId, createdAt])
  @@index([operatorOpenId])
  @@map("perf_cycle_rollbacks")
  @@schema("performance")
}

/// 参与人：单人评估过程的聚合根；加入周期时先固化前缀与表单绑定，启动时再复核组织快照。
model PerfParticipant {
  id                     Int                   @id @default(autoincrement()) /// 内部自增主键
  cycleId                Int                   @map("cycle_id") /// 所属周期
  employeeOpenId         String                @map("employee_open_id") /// 被考核员工飞书 open_id（逻辑外键 lark_users，展示层 join）
  leaderOpenIdSnapshot   String?               @map("leader_open_id_snapshot") /// 启动时直属 Leader open_id 快照；上级评估/团队看板按此过滤
  departmentIdSnapshot   String?               @map("department_id_snapshot") /// 启动时部门 open_department_id 快照
  jobLevelSnapshot       Json?                 @map("job_level_snapshot") /// 启动时职级/岗位快照（来自 corehr job_level 等对象，含 jobCategory 岗位类别如 D/M）；用于维度 applicable_scope 匹配与展示
  jobLevelPrefixSnapshot PerfJobLevelPrefix?   @map("job_level_prefix_snapshot") /// 从 CoreHR 职级 code 提取的 D/M 前缀；遗留数据可为空
  formSnapshotId         Int?                  @map("form_snapshot_id") /// 精确匹配的周期表单快照；与职级前缀成对存在
  status                 PerfParticipantStatus @default(ACTIVE) /// 结果生命周期；评估进度由任务与统一提交派生
  evaluationLockedAt     DateTime?             @map("evaluation_locked_at") /// 首次成功校准时写入；与首条校准决定同事务产生
  createdAt              DateTime              @default(now()) @map("created_at") /// 创建时间
  updatedAt              DateTime              @updatedAt @map("updated_at") /// 最近更新时间

  cycle        PerfCycle              @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  formSnapshot PerfCycleFormSnapshot? @relation(fields: [formSnapshotId], references: [id], onDelete: Restrict)

  reviewerAssignments   PerfReviewerAssignment[]
  aiReport              PerfAiReport?
  calibrations          PerfCalibration[]
  redLineFindings       PerfRedLineFinding[]
  resultVersions        PerfResultVersion[]
  appeals               PerfAppeal[]
  interviews            PerfInterview[]
  evaluationTasks       PerfEvaluationTask[]
  evaluationSubmissions PerfEvaluationSubmission[]
  stageResults          PerfStageResult[]

  @@unique([cycleId, employeeOpenId]) /// 一人一周期仅一条参与记录
  @@unique([id, cycleId]) /// 供统一任务复合外键保证任务与参与人属于同一周期
  @@index([cycleId, status])
  @@index([cycleId, leaderOpenIdSnapshot])
  @@index([cycleId, jobLevelPrefixSnapshot])
  @@index([employeeOpenId])
  @@index([formSnapshotId])
  @@map("perf_participants")
  @@schema("performance")
}

/// 统一评估任务事实；开始时间是硬门槛，提醒截止仅供通知，不会关闭任务。
/// openedAt 一旦写入不得清空，以免调整计划后把已经开放的任务重新关闭。
model PerfEvaluationTask {
  id                 Int                    @id @default(autoincrement()) /// 内部自增主键
  cycleId            Int                    @map("cycle_id") /// 所属周期，冗余保存便于启动与通知队列查询
  participantId      Int                    @map("participant_id") /// 所属参与者
  type               PerfEvaluationTaskType /// SELF / PEER / MANAGER / AI
  assigneeOpenId     String?                @map("assignee_open_id") /// 自评员工或 Leader；PEER 指派人和 AI 任务为空
  startAt            DateTime?              @map("start_at") /// 人工任务硬开放时间；AI 等待有效输入时为空
  reminderDeadlineAt DateTime?              @map("reminder_deadline_at") /// 软提醒时间，超过后仍允许首次提交与重新提交
  openedAt           DateTime?              @map("opened_at") /// 首次开放时间；不可逆开放事实
  completedAt        DateTime?              @map("completed_at") /// 当前任务完成时间；后续重开规则由对应业务 Ticket 定义
  createdAt          DateTime               @default(now()) @map("created_at") /// 创建时间
  updatedAt          DateTime               @updatedAt @map("updated_at") /// 最近更新时间

  cycle              PerfCycle               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  participant        PerfParticipant         @relation(fields: [participantId, cycleId], references: [id, cycleId], onDelete: Cascade)
  notificationEvents PerfNotificationEvent[]

  @@unique([participantId, type])
  @@index([cycleId, type, startAt])
  @@index([cycleId, type, reminderDeadlineAt])
  @@index([reminderDeadlineAt, completedAt, openedAt]) /// 通知模块全局扫描已开放且未完成的软截止任务
  @@index([assigneeOpenId, type, openedAt])
  @@map("perf_evaluation_tasks")
  @@schema("performance")
}

/// 评审员指派（产品 §6.4.1）：推荐/指定/补充产生的评审任务。
/// 更换评审员时旧记录置 REPLACED 并新建记录，故 (participant, reviewer, relation) 不设唯一约束。
model PerfReviewerAssignment {
  id              Int                  @id @default(autoincrement()) /// 内部自增主键
  cycleId         Int                  @map("cycle_id") /// 所属周期（冗余自 participant，加速评审员任务列表查询）
  participantId   Int                  @map("participant_id") /// 被评估的参与者
  reviewerOpenId  String               @map("reviewer_open_id") /// 评审员飞书 open_id
  relation        PerfReviewerRelation @map("relation") /// 与被评人关系
  source          PerfReviewerSource   @map("source") /// 指派来源
  recommendReason String?              @map("recommend_reason") /// 系统推荐理由（source=RECOMMENDED 时给出）
  status          PerfAssignmentStatus @default(PENDING) /// 指派状态
  createdAt       DateTime             @default(now()) @map("created_at") /// 创建时间
  updatedAt       DateTime             @updatedAt @map("updated_at") /// 最近更新时间

  cycle       PerfCycle                  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  /// 与 cycleId 组成复合外键，数据库同时校验指派与参与者属于同一周期。
  participant PerfParticipant            @relation(fields: [participantId, cycleId], references: [id, cycleId], onDelete: Cascade)
  submissions PerfEvaluationSubmission[]

  @@unique([id, participantId, reviewerOpenId]) /// 供 360°评估提交复合外键锁定指派归属，防止提交伪造他人的评审员指派
  @@index([reviewerOpenId, status]) /// 「我的评审任务」列表
  @@index([participantId])
  @@index([cycleId])
  /// “未替换指派唯一”和四类关系/Leader 排除由迁移中的部分唯一索引、CHECK 与触发器保证。
  @@map("perf_reviewer_assignments")
  @@schema("performance")
}

/// 统一人工评估提交（ADR-0009）：SELF/PEER/MANAGER 三类人工答卷的统一父记录，AI 继续走独立异步任务不落此表。
/// 同一 (participant, stage, reviewer) 至多一份 SUBMITTED（当前生效）与至多一份 DRAFT（编辑草稿），
/// 由数据库部分唯一索引 perf_evaluation_submissions_active_submitted_key / _active_draft_key 保证，不建答案历史表；
/// INVALIDATED 仅用于结构变更时保留旧快照答卷与无法兼容的答案，不占用当前生效/草稿唯一槽位；
/// MANAGER 阶段还由迁移中的跨填写人部分唯一索引保证每名参与者至多一份生效提交与一份草稿；
/// 重新提交时由 service 原子替换当前 SUBMITTED 行内容，不新增行。
model PerfEvaluationSubmission {
  id                   Int                    @id @default(autoincrement()) /// 内部自增主键
  cycleId              Int                    @map("cycle_id") /// 所属周期，冗余保存便于按周期统计查询
  participantId        Int                    @map("participant_id") /// 所属参与者
  stage                PerfEvaluationTaskType @map("stage") /// SELF/PEER/MANAGER；AI 不走人工提交，数据库 CHECK 禁止取值 'AI'
  reviewerOpenId       String                 @map("reviewer_open_id") /// 填写人 open_id：SELF=员工本人，PEER=评审员，MANAGER=须匹配考核 Leader 快照，均由数据库触发器校验。注意：触发器只在 INSERT/UPDATE 时按当时快照校验；更换 Leader 快照不会追溯校验既有 MANAGER 提交行，快照变更后的既有提交处置由服务层负责
  reviewerAssignmentId Int?                   @map("reviewer_assignment_id") /// 360°提交关联的有效评审员指派；仅 PEER 非空，复合外键保证指派归属同一参与者与评审员
  formSnapshotId       Int                    @map("form_snapshot_id") /// 提交所依据的周期表单快照；维度与字段作答据此定位稳定 key
  status               PerfReviewStatus       @default(DRAFT) /// DRAFT=编辑草稿，SUBMITTED=当前生效，INVALIDATED=结构变更失效历史
  submittedAt          DateTime?              @map("submitted_at") /// 最近一次原子生效提交时间；重新提交时整体刷新
  submittedByOpenId    String?                @map("submitted_by_open_id") /// 最近一次提交的操作人 open_id（审计用，通常等于 reviewer_open_id）
  createdAt            DateTime               @default(now()) @map("created_at") /// 创建时间
  updatedAt            DateTime               @updatedAt @map("updated_at") /// 最近编辑时间（草稿自动保存或提交刷新）

  cycle              PerfCycle                  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  participant        PerfParticipant            @relation(fields: [participantId, cycleId], references: [id, cycleId], onDelete: Cascade)
  formSnapshot       PerfCycleFormSnapshot      @relation(fields: [formSnapshotId], references: [id], onDelete: Restrict)
  reviewerAssignment PerfReviewerAssignment?    @relation(fields: [reviewerAssignmentId, participantId, reviewerOpenId], references: [id, participantId, reviewerOpenId], onDelete: Restrict)
  dimensionAnswers   PerfEvaluationDimensionAnswer[]

  @@unique([id, formSnapshotId]) /// 供维度作答复合外键锁定表单快照，防止跨快照写入
  @@index([cycleId, stage])
  @@index([participantId, stage, status])
  @@index([reviewerOpenId, stage, status])
  @@index([reviewerAssignmentId])
  @@index([formSnapshotId])
  @@map("perf_evaluation_submissions")
  @@schema("performance")
}

/// 新版维度作答：计分值直接归属维度；草稿允许计分值为空，正式提交完整性由业务服务校验。
model PerfEvaluationDimensionAnswer {
  id               Int                    @id @default(autoincrement()) /// 内部自增主键
  submissionId     Int                    @map("submission_id") /// 所属统一评估提交
  formSnapshotId   Int                    @map("form_snapshot_id") /// 冗余快照 ID；复合外键保证与提交一致
  subformKey       String                 @map("subform_key") /// 周期快照中的稳定子表单 key
  dimensionKey     String                 @map("dimension_key") /// 周期快照中的稳定维度 key
  scoringMethod    PerfFormScoringMethod? @map("scoring_method") /// 计分维度的评级/分数方式；非计分维度为空
  rawLevel         PerfRatingSymbol?      @map("raw_level") /// 评级维度原始选择
  rawScore         Decimal?               @map("raw_score") @db.Decimal(5, 2) /// 分数维度原始 0～100 分
  calculationScore Decimal?               @map("calculation_score") @db.Decimal(5, 2) /// 按周期规则统一换算后的 0～100 分
  derivedLevel     PerfRatingSymbol?      @map("derived_level") /// 计算分按周期评级区间派生的维度等级
  createdAt        DateTime               @default(now()) @map("created_at") /// 创建时间
  updatedAt        DateTime               @updatedAt @map("updated_at") /// 草稿或重新提交最近替换时间

  submission PerfEvaluationSubmission @relation(fields: [submissionId, formSnapshotId], references: [id, formSnapshotId], onDelete: Cascade)
  fields     PerfEvaluationFieldAnswer[]

  @@unique([submissionId, dimensionKey]) /// 同一提交内同一维度最多一条作答
  @@index([formSnapshotId, dimensionKey]) /// 跨提交按稳定维度聚合
  @@map("perf_evaluation_dimension_answers")
  @@schema("performance")
}

/// 新版字段作答：只承载非计分字段的受控 JSON 值，并从属于一条维度作答。
model PerfEvaluationFieldAnswer {
  id                Int              @id @default(autoincrement()) /// 内部自增主键
  dimensionAnswerId Int              @map("dimension_answer_id") /// 所属维度作答
  fieldKey          String           @map("field_key") /// 周期快照中的稳定字段 key
  fieldType         PerfFormFieldType @map("field_type") /// 提交时字段类型快照
  value             Json /// 与字段类型匹配的受控结构化值
  createdAt         DateTime         @default(now()) @map("created_at") /// 创建时间
  updatedAt         DateTime         @updatedAt @map("updated_at") /// 草稿或重新提交最近替换时间

  dimensionAnswer PerfEvaluationDimensionAnswer @relation(fields: [dimensionAnswerId], references: [id], onDelete: Cascade)

  @@unique([dimensionAnswerId, fieldKey]) /// 同一维度作答内同一字段最多一条作答
  @@index([fieldKey]) /// 跨提交按稳定字段查询
  @@map("perf_evaluation_field_answers")
  @@schema("performance")
}

/// 可复算的评估阶段结果；同一配置版本内随当前有效答卷覆盖更新，新配置版本产生新行并保留旧结果。
model PerfStageResult {
  id                   Int                    @id @default(autoincrement()) /// 内部自增主键
  cycleId              Int                    @map("cycle_id") /// 所属周期；与参与者、配置版本组成复合归属约束
  participantId        Int                    @map("participant_id") /// 所属参与者
  cycleConfigVersionId Int                    @map("cycle_config_version_id") /// 本次计算使用的周期配置快照版本
  stage                PerfEvaluationTaskType /// SELF / PEER / MANAGER / AI；Ticket 08 首先写入 PEER
  status               PerfStageResultStatus /// READY 或 NO_DATA
  reviewerCount        Int                    @default(0) @map("reviewer_count") /// 实际进入计算的有效评审员数量
  compositeScore       Decimal?               @map("composite_score") @db.Decimal(5, 2) /// 四舍五入两位后的阶段综合分；NO_DATA 为空
  initialLevel         PerfRatingSymbol?      @map("initial_level") /// 综合分映射出的初始等级；NO_DATA 为空
  stageLevel           PerfRatingSymbol?      @map("stage_level") /// 应用约束后的阶段等级；NO_DATA 为空
  constraintReasons    Json                   @default("[]") @map("constraint_reasons") /// 命中的受控约束及前后等级快照
  calculationDetail    Json                   @map("calculation_detail") /// 未舍入分数、有效/排除输入、关系均分与调整权重等可解释明细
  calculatedAt         DateTime               @default(now()) @map("calculated_at") /// 最近一次基于当前有效答卷完成计算的时间
  createdAt            DateTime               @default(now()) @map("created_at") /// 当前配置版本结果首次创建时间
  updatedAt            DateTime               @updatedAt @map("updated_at") /// 当前配置版本结果最近重算时间

  cycle         PerfCycle                  @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  participant   PerfParticipant            @relation(fields: [participantId, cycleId], references: [id, cycleId], onDelete: Restrict)
  configVersion PerfCycleConfigVersion     @relation(fields: [cycleConfigVersionId, cycleId], references: [id, cycleId], onDelete: Restrict)
  dimensions    PerfStageDimensionResult[]

  @@unique([participantId, stage, cycleConfigVersionId])
  @@index([cycleId, stage, status])
  @@index([cycleConfigVersionId])
  @@map("perf_stage_results")
  @@schema("performance")
}

/// 阶段结果下的关系化维度聚合；随父阶段结果重算替换，不单独形成历史版本。
model PerfStageDimensionResult {
  id            Int              @id @default(autoincrement()) /// 内部自增主键
  stageResultId Int              @map("stage_result_id") /// 所属阶段结果
  dimensionKey  String           @map("dimension_key") /// 周期表单快照中的稳定维度 key
  name          String /// 计算时的维度名称快照
  weight        Decimal          @db.Decimal(5, 2) /// 维度基础权重
  isCore        Boolean          @map("is_core") /// 是否核心维度
  score         Decimal          @db.Decimal(65, 30) /// 保留高精度的维度聚合分
  level         PerfRatingSymbol /// 维度聚合分映射等级
  createdAt     DateTime         @default(now()) @map("created_at") /// 首次写入时间
  updatedAt     DateTime         @updatedAt @map("updated_at") /// 最近重算时间

  stageResult        PerfStageResult             @relation(fields: [stageResultId], references: [id], onDelete: Cascade)
  relationAggregates PerfPeerRelationAggregate[]

  @@unique([stageResultId, dimensionKey])
  @@index([dimensionKey])
  @@map("perf_stage_dimension_results")
  @@schema("performance")
}

/// 360°维度内按评审关系聚合的均分与归一化权重；只保存存在有效提交的关系。
model PerfPeerRelationAggregate {
  id                     Int                  @id @default(autoincrement()) /// 内部自增主键
  stageDimensionResultId Int                  @map("stage_dimension_result_id") /// 所属阶段维度结果
  relation               PerfReviewerRelation /// 组织负责人/项目负责人/同事/跨部门协作方
  baseWeight             Decimal              @map("base_weight") @db.Decimal(5, 2) /// 配置快照中的基础权重
  adjustedWeight         Decimal              @map("adjusted_weight") @db.Decimal(65, 30) /// 有效关系集合内的高精度归一化权重
  reviewerCount          Int                  @map("reviewer_count") /// 进入本关系均分的有效评审员数量
  score                  Decimal              @db.Decimal(65, 30) /// 同一关系内评审员计算分的算术平均
  createdAt              DateTime             @default(now()) @map("created_at") /// 首次写入时间
  updatedAt              DateTime             @updatedAt @map("updated_at") /// 最近重算时间

  stageDimensionResult PerfStageDimensionResult @relation(fields: [stageDimensionResultId], references: [id], onDelete: Cascade)

  @@unique([stageDimensionResultId, relation])
  @@index([relation])
  @@map("perf_peer_relation_aggregates")
  @@schema("performance")
}

/// AI 独立异步参考报告；不进入参与者状态机，也不参与人工阶段跨阶段加权。
/// 每参与者一份，输入修订变化后原记录重新排队；仅当前 Leader 与授权 HR/Admin 可见。
model PerfAiReport {
  id                 Int                 @id @default(autoincrement()) /// 内部自增主键
  participantId      Int                 @unique @map("participant_id") /// 所属参与者
  status             PerfAiReportStatus  @default(PENDING) /// 独立任务状态；失败、超时或未生成均不阻塞人工流程
  referenceLevel     PerfRatingSymbol?   @map("reference_level") /// AI 直接参考等级；只作参考，不写入人工阶段加权结果
  summary            String?             @map("summary") /// 综合摘要
  highlights         Json?               @map("highlights") /// 亮点：[{ title, evidence }]
  improvements       Json?               @map("improvements") /// 待改进点：[{ title, evidence }]
  riskFlags          Json?               @map("risk_flags") /// 风险/一致性提示：[{ type, description }]
  inputsDigest       Json?               @map("inputs_digest") /// 输入来源元数据（当前有效提交/阶段结果 id 与更新时间）
  inputSnapshot      Json?               @map("input_snapshot") /// 实际生成输入快照；只包含当前有效人工提交和当前配置阶段结果
  inputRevision      String?             @map("input_revision") /// inputSnapshot 的 SHA-256；相同修订幂等
  processingRevision String?             @map("processing_revision") /// 当前运行任务领取的输入修订；完成时必须与 inputRevision 一致
  attemptCount       Int                 @default(0) @map("attempt_count") /// 当前输入修订已领取次数；输入变化或人工重试时归零
  availableAt        DateTime            @default(now()) @map("available_at") /// PENDING/FAILED 下一次允许领取时间
  startedAt          DateTime?           @map("started_at") /// 最近一次开始生成时间；用于识别并恢复超时任务
  errorMessage       String?             @map("error_message") /// 失败原因（status=FAILED）
  generatedAt        DateTime?           @map("generated_at") /// 生成完成时间
  reviewedByOpenId   String?             @map("reviewed_by_open_id") /// 处理人（Leader/HR）open_id
  reviewedAction     PerfAiReviewAction? @map("reviewed_action") /// 处理动作；人工结论优先于 AI 输出
  createdAt          DateTime            @default(now()) @map("created_at") /// 任务创建时间
  updatedAt          DateTime            @updatedAt @map("updated_at") /// 最近更新时间

  participant PerfParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([status, availableAt]) /// 异步 worker 按状态和可领取时间扫描
  @@map("perf_ai_reports")
  @@schema("performance")
}

/// 校准决定（产品 §8.15）：append-only，不可更新/删除；KEEP 与 ADJUST 都新增一条
model PerfCalibration {
  id                      Int                     @id @default(autoincrement()) /// 内部自增主键
  participantId           Int                     @map("participant_id") /// 所属参与者
  decision                PerfCalibrationDecision /// 显式 KEEP / ADJUST；所有新增记录必须由业务显式写入
  isLegacy                Boolean                 @default(false) @map("is_legacy") /// 仅迁移前历史为 true；数据库拒绝新增 legacy 记录
  beforeLevel             String?                 @map("before_level") /// 决定前当前等级；首条取 MANAGER 权威阶段等级
  afterLevel              String                  @map("after_level") /// 决定后的等级；KEEP 取当时 MANAGER 权威等级，可能与上次校准等级不同
  reason                  String? /// ADJUST 必填；KEEP 可选说明
  inputRevision           String?                 @map("input_revision") /// 决定时完整人工评估、阶段结果与红线输入的 SHA-256；历史记录可空
  operatorOpenId          String                  @map("operator_open_id") /// 操作人（当前 Leader/授权 HR/Admin）open_id
  createdAt               DateTime                @default(now()) @map("created_at") /// 记录时间
  invalidatedAt           DateTime?               @map("invalidated_at") /// 周期整体退回时一次性写入；决定历史仍永久保留
  invalidatedByRollbackId Int?                    @map("invalidated_by_rollback_id") /// 导致本决定失效的周期退回记录

  participant           PerfParticipant     @relation(fields: [participantId], references: [id], onDelete: Restrict)
  invalidatedByRollback PerfCycleRollback?  @relation(fields: [invalidatedByRollbackId], references: [id], onDelete: Restrict)
  resultVersions        PerfResultVersion[] /// 以本决定为来源发布的结果版本
  resolvedAppeals       PerfAppeal[]        @relation("AppealResolutionCalibration") /// 以本决定作为处理依据关闭的申诉

  @@unique([id, participantId]) /// 申诉处理复合外键保证决定与参与者一致
  @@index([participantId])
  @@index([participantId, invalidatedAt])
  @@index([invalidatedByRollbackId])
  @@map("perf_calibrations")
  @@schema("performance")
}

/// 红线确认/撤销事件；append-only，不以 UPDATE 覆盖已确认事实。
model PerfRedLineFinding {
  id             Int               @id @default(autoincrement()) /// 内部自增主键
  participantId  Int               @map("participant_id") /// 所属参与者
  action         PerfRedLineAction /// CONFIRM / REVOKE
  findingType    String            @map("finding_type") /// 受控业务类型或公司制度类型标识
  facts          String /// 事实说明
  evidence       Json /// 证据列表或结构化证据引用
  reason         String /// 确认或撤销原因
  revokeOfId     Int?              @unique @map("revoke_of_id") /// REVOKE 指向被撤销的 CONFIRM；每条确认最多撤销一次
  operatorOpenId String            @map("operator_open_id") /// HR/Admin 操作人 open_id
  createdAt      DateTime          @default(now()) @map("created_at") /// 事件时间

  participant PerfParticipant      @relation(fields: [participantId], references: [id], onDelete: Restrict)
  revokeOf    PerfRedLineFinding?  @relation("PerfRedLineRevocation", fields: [revokeOfId], references: [id], onDelete: Restrict)
  revokedBy   PerfRedLineFinding[] @relation("PerfRedLineRevocation")

  @@index([participantId, action, createdAt])
  @@map("perf_red_line_findings")
  @@schema("performance")
}

/// 员工可见的不可变结果版本（Ticket 14）：发布即冻结全部业务内容。
/// append-only 语义由触发器保证——仅允许 superseded_at / confirmed_at / confirmed_by_open_id
/// 从 NULL 一次性回填，其余列禁止 UPDATE，且禁止 DELETE。
/// 员工确认精确绑定版本；同一参与者仅一个当前版本（superseded_at IS NULL 部分唯一索引）。
model PerfResultVersion {
  id                      Int              @id @default(autoincrement()) /// 内部自增主键
  participantId           Int              @map("participant_id") /// 所属参与者
  version                 Int /// 参与者内递增版本号，从 1 开始
  finalLevel              PerfRatingSymbol @map("final_level") /// 员工可见的最终等级；有效红线强制为 C（数据库触发器兜底）
  employeeExplanation     String?          @map("employee_explanation") /// 员工可见解释；发布时收敛，不含内部校准讨论
  sourceCalibrationId     Int?             @map("source_calibration_id") /// 来源校准决定；仅迁移回填的历史版本可为空
  resultSnapshot          Json             @map("result_snapshot") /// 隐私收敛后的员工可见结果快照：{ cycle, manager{compositeScore,dimensions,overallComment}, self, promotion }
  publishedByOpenId       String           @map("published_by_open_id") /// 发布操作人 open_id；迁移回填为 system:migration
  publishedAt             DateTime         @default(now()) @map("published_at") /// 发布时间
  supersededAt            DateTime?        @map("superseded_at") /// 被新版本替代时间；新版本发布同事务一次性写入
  confirmedAt             DateTime?        @map("confirmed_at") /// 员工确认本版本的时间
  confirmedByOpenId       String?          @map("confirmed_by_open_id") /// 确认人 open_id（员工本人）
  createdAt               DateTime         @default(now()) @map("created_at") /// 创建时间
  invalidatedAt           DateTime?        @map("invalidated_at") /// 周期整体退回时一次性写入；与正常新版本替代语义分离
  invalidatedByRollbackId Int?             @map("invalidated_by_rollback_id") /// 导致本版本失效的周期退回记录

  participant           PerfParticipant    @relation(fields: [participantId], references: [id], onDelete: Restrict)
  sourceCalibration     PerfCalibration?   @relation(fields: [sourceCalibrationId], references: [id], onDelete: Restrict)
  invalidatedByRollback PerfCycleRollback? @relation(fields: [invalidatedByRollbackId], references: [id], onDelete: Restrict)
  appeals               PerfAppeal[]       @relation("AppealedResultVersion") /// 针对本版本发起的申诉（每参与者至多一次）

  @@unique([id, participantId]) /// 申诉复合外键保证版本与参与者一致
  @@unique([participantId, version]) /// 参与者内版本号唯一
  @@index([participantId, supersededAt]) /// 读取当前有效版本
  @@index([sourceCalibrationId])
  @@index([participantId, invalidatedAt])
  @@index([invalidatedByRollbackId])
  @@map("perf_result_versions")
  @@schema("performance")
}

/// 申诉记录（产品 §8.17）；与员工确认互斥，处理闭环可能触发再次校准
model PerfAppeal {
  id                      Int              @id @default(autoincrement()) /// 内部自增主键
  participantId           Int              @map("participant_id") /// 所属参与者；服务聚合锁与数据库触发器兜底每人每周期仅一次申诉
  resultVersionId         Int              @map("result_version_id") /// 员工发起申诉时看到的当前有效结果版本
  resolutionCalibrationId Int?             @map("resolution_calibration_id") /// 处理时参考的最新校准决定；未重新校准时仍指向原来源决定
  isLegacy                Boolean          @default(false) @map("is_legacy") /// 迁移前历史申诉为 true；允许保留旧系统的重复申诉事实，新建记录必须为 false
  reason                  String           @map("reason") /// 申诉理由
  attachments             Json?            @map("attachments") /// 申诉附件：[{ name, url/fileToken }]
  status                  PerfAppealStatus @default(PENDING) /// 处理状态
  handlerOpenId           String?          @map("handler_open_id") /// 实际处理人（当前 Leader、授权 HR 或 Admin）open_id
  conclusion              String?          @map("conclusion") /// 处理结论
  resultAdjusted          Boolean          @default(false) @map("result_adjusted") /// 是否因员工可见等级变化发布了新版本
  resolvedAt              DateTime?        @map("resolved_at") /// 处理完成时间
  createdAt               DateTime         @default(now()) @map("created_at") /// 申诉发起时间
  updatedAt               DateTime         @updatedAt @map("updated_at") /// 最近更新时间
  invalidatedAt           DateTime?        @map("invalidated_at") /// 周期整体退回时一次性写入；申诉历史仍永久保留
  invalidatedByRollbackId Int?             @map("invalidated_by_rollback_id") /// 导致本申诉链失效的周期退回记录

  participant           PerfParticipant    @relation(fields: [participantId], references: [id], onDelete: Restrict)
  resultVersion         PerfResultVersion  @relation("AppealedResultVersion", fields: [resultVersionId, participantId], references: [id, participantId], onDelete: Restrict)
  resolutionCalibration PerfCalibration?   @relation("AppealResolutionCalibration", fields: [resolutionCalibrationId, participantId], references: [id, participantId], onDelete: Restrict)
  invalidatedByRollback PerfCycleRollback? @relation(fields: [invalidatedByRollbackId], references: [id], onDelete: Restrict)
  interviews            PerfInterview[]

  @@index([resultVersionId])
  @@index([resolutionCalibrationId])
  @@index([status]) /// 申诉处理队列
  @@index([handlerOpenId])
  @@index([participantId, invalidatedAt])
  @@index([invalidatedByRollbackId])
  @@map("perf_appeals")
  @@schema("performance")
}

/// 面谈记录（产品 §8.18）：申诉面谈关联 appeal_id，选择性面谈可独立创建
model PerfInterview {
  id                 Int               @id @default(autoincrement()) /// 内部自增主键
  participantId      Int               @map("participant_id") /// 所属参与者
  appealId           Int?              @map("appeal_id") /// 关联申诉；仅 type=APPEAL 时存在
  type               PerfInterviewType @map("type") /// 面谈类型
  participantOpenIds String[]          @default([]) @map("participant_open_ids") /// 面谈参与人 open_id 列表（Leader/HR 等）
  content            String?           @map("content") /// 面谈内容纪要
  employeeFeedback   String?           @map("employee_feedback") /// 员工反馈
  conclusion         String?           @map("conclusion") /// 面谈结论
  resultAdjusted     Boolean           @default(false) @map("result_adjusted") /// 面谈后结果是否调整（调整走校准记录）
  createdAt          DateTime          @default(now()) @map("created_at") /// 创建时间
  updatedAt          DateTime          @updatedAt @map("updated_at") /// 最近更新时间（纪要可补充完善）

  participant PerfParticipant @relation(fields: [participantId], references: [id], onDelete: Restrict)
  appeal      PerfAppeal?     @relation(fields: [appealId], references: [id], onDelete: Restrict)

  @@index([participantId])
  @@index([appealId])
  @@map("perf_interviews")
  @@schema("performance")
}

/// 通知发送记录（产品 §8.19）：每次发送落库；重试更新本行 retry_count/status。
/// sourceEventId 是事件消费幂等底线；手工通知可为空。
model PerfNotification {
  id             Int                     @id @default(autoincrement()) /// 内部自增主键
  sourceEventId  Int?                    @unique @map("source_event_id") /// 来源通知事件；同一事件最多产生一条发送记录
  receiverOpenId String                  @map("receiver_open_id") /// 接收人飞书 open_id
  channel        PerfNotificationChannel @map("channel") /// 发送通道
  template       String                  @map("template") /// 通知模板标识（产品 §9.10：评审启动/自评提醒/催办/结果推送等）
  payload        Json?                   @map("payload") /// 渲染后的消息/卡片内容与业务上下文
  status         PerfNotificationStatus  @default(PENDING) /// 发送状态
  retryCount     Int                     @default(0) @map("retry_count") /// 已重试次数；达上限置 FAILED 支持手动补发
  errorMessage   String?                 @map("error_message") /// 最近一次失败原因
  sentAt         DateTime?               @map("sent_at") /// 发送成功时间
  createdAt      DateTime                @default(now()) @map("created_at") /// 创建时间
  updatedAt      DateTime                @updatedAt @map("updated_at") /// 最近更新时间（重试簿记）

  sourceEvent PerfNotificationEvent? @relation(fields: [sourceEventId], references: [id], onDelete: Restrict)

  @@index([receiverOpenId])
  @@index([status]) /// 重试队列扫描
  @@map("perf_notifications")
  @@schema("performance")
}

/// 通知事件 outbox：业务事务写入后，由通知消费者幂等生成 perf_notifications。
/// dedupeKey 是稳定业务键；payload 保存渲染上下文与启动失败的具体问题。
model PerfNotificationEvent {
  id             Int                         @id @default(autoincrement()) /// 内部自增主键
  dedupeKey      String                      @unique @map("dedupe_key") @db.VarChar(512) /// 任务/周期事件稳定去重键
  type           PerfNotificationEventType /// 任务开放、软提醒或周期启动失败
  status         PerfNotificationEventStatus @default(PENDING) /// 消费状态
  cycleId        Int?                        @map("cycle_id") /// 所属周期；历史事件保留关系并禁止删除来源
  taskId         Int?                        @map("task_id") /// 所属评估任务；启动失败事件为空
  stage          PerfEvaluationTaskType?     @map("stage") /// SELF / PEER / MANAGER；启动失败事件为空
  openedAt       DateTime?                   @map("opened_at") /// 任务实际首次开放时间
  deadlineAt     DateTime?                   @map("deadline_at") /// 任务软提醒截止时间
  receiverOpenId String                      @map("receiver_open_id") /// 事件最终接收人 open_id；抄送人拆成独立事件
  channel        PerfNotificationChannel     @map("channel") /// 发送通道
  template       String                      @map("template") /// 受控通知模板标识
  payload        Json?                       @map("payload") /// 消息上下文；启动失败包含 issues 数组
  attemptCount   Int                         @default(0) @map("attempt_count") /// 事件消费失败次数
  availableAt    DateTime                    @default(now()) @map("available_at") /// 下一次允许消费时间
  processedAt    DateTime?                   @map("processed_at") /// 成功生成发送记录时间
  errorMessage   String?                     @map("error_message") /// 最近一次消费失败原因
  createdAt      DateTime                    @default(now()) @map("created_at") /// 业务事件首次入队时间
  updatedAt      DateTime                    @updatedAt @map("updated_at") /// 重试状态更新时间

  cycle         PerfCycle?          @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  task          PerfEvaluationTask? @relation(fields: [taskId], references: [id], onDelete: Restrict)
  notifications PerfNotification[]

  @@index([status, availableAt])
  @@index([cycleId, type, stage])
  @@index([taskId, type, openedAt, deadlineAt])
  @@index([receiverOpenId, createdAt])
  @@map("perf_notification_events")
  @@schema("performance")
}

/// 操作日志（产品 §8.20）：append-only 审计流水，禁止 UPDATE/DELETE
model AuditLog {
  id             Int      @id @default(autoincrement()) /// 内部自增主键
  operatorOpenId String   @map("operator_open_id") /// 操作人飞书 open_id
  action         String   @map("action") /// 操作类型（如 cycle.start / calibration.adjust / report.export）
  targetType     String   @map("target_type") /// 操作对象类型（表/聚合名）
  targetId       String   @map("target_id") /// 操作对象 ID（统一存字符串，兼容 open_id 与自增 id）
  before         Json?    @map("before") /// 变更前快照
  after          Json?    @map("after") /// 变更后快照
  reason         String?  @map("reason") /// 操作原因（校准调整、退回等场景必填，由 service 保证）
  ip             String?  @map("ip") /// 操作来源 IP 或客户端信息
  createdAt      DateTime @default(now()) @map("created_at") /// 操作时间

  @@index([targetType, targetId])
  @@index([operatorOpenId])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("performance")
}

/// RBAC 显式授权（产品 §3.8）：仅维护 HR 与超级管理员；
/// EMPLOYEE/REVIEWER/LEADER 由 participant/assignment/leader 快照派生，不入本表
model RoleGrant {
  id              Int      @id @default(autoincrement()) /// 内部自增主键
  userOpenId      String   @map("user_open_id") /// 被授权人飞书 open_id
  role            PerfRole @map("role") /// 授予角色（实际使用 HR/ADMIN）
  orgScope        String[] @default([]) @map("org_scope") /// 授权部门范围（open_department_id 列表，含子树）；ADMIN 留空表示全局
  grantedByOpenId String?  @map("granted_by_open_id") /// 授权人 open_id
  createdAt       DateTime @default(now()) @map("created_at") /// 授权时间
  updatedAt       DateTime @updatedAt @map("updated_at") /// 最近更新时间（调整 org_scope）

  @@unique([userOpenId, role]) /// 同人同角色仅一条授权，撤销为物理删除并写审计
  @@map("role_grants")
  @@schema("performance")
}

/// 系统参数（产品 §9.11）：key-value 配置，如 AI 开关、飞书文档默认目录、默认评级、导出权限
model SystemConfig {
  id              Int      @id @default(autoincrement()) /// 内部自增主键
  key             String   @unique @map("key") /// 参数键，如 ai.enabled / export.allowed_roles
  value           Json     @map("value") /// 参数值，统一 JSON 存储便于结构化配置
  description     String?  @map("description") /// 参数说明
  updatedByOpenId String?  @map("updated_by_open_id") /// 最近修改人 open_id
  createdAt       DateTime @default(now()) @map("created_at") /// 创建时间
  updatedAt       DateTime @updatedAt @map("updated_at") /// 最近更新时间

  @@map("system_configs")
  @@schema("performance")
}

/// 报表导出任务（产品 §7.18，研发文档 §8.7）：异步生成 xlsx，前端任务列表轮询；导出动作同时写 audit_logs
model ReportExportTask {
  id             Int                @id @default(autoincrement()) /// 内部自增主键
  cycleId        Int?               @map("cycle_id") /// 关联周期；周期（软删场景外的物理删除）后置空保留任务历史
  type           String             @map("type") /// 报表类型标识（结果汇总/维度明细/申诉记录等）
  params         Json?              @map("params") /// 导出参数：{ orgScope, fields, filters }
  status         ReportExportStatus @default(PENDING) /// 任务状态；worker 轮询 PENDING
  filePath       String?            @map("file_path") /// 产物存储路径/下载地址
  errorMessage   String?            @map("error_message") /// 失败原因
  operatorOpenId String             @map("operator_open_id") /// 发起人 open_id（导出权限校验对象）
  finishedAt     DateTime?          @map("finished_at") /// 完成时间
  createdAt      DateTime           @default(now()) @map("created_at") /// 创建时间
  updatedAt      DateTime           @updatedAt @map("updated_at") /// 最近更新时间

  cycle PerfCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@index([operatorOpenId])
  @@index([status]) /// worker 任务队列扫描
  @@index([cycleId])
  @@map("report_export_tasks")
  @@schema("performance")
}
